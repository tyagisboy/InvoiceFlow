{
  "name": "invoice-flow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:build": "electron-packager . \"Invoice Flow\" --platform=win32 --arch=x64 --out=dist-electron --icon=icon.ico --overwrite",
    "electron:dist": "electron-builder --win",
    "electron:installer": "node build-installer.cjs"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "22.3.27",
    "electron-builder": "^24.13.3",
    "electron-winstaller": "^5.4.0",
    "png-to-ico": "^3.0.1",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.invoice.flow",
    "productName": "Invoice Flow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "electron-main.cjs",
      "preload.cjs",
      "package.json",
      "icon.ico",
      "icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "uninstallDisplayName": "Invoice Flow",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "createDesktopShortcut": "always"
    }
  }
}
